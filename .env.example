# Foreverly – Umgebungsvariablen
# Kopiere diese Datei nach `.env` und trage deine eigenen Werte ein.
# Diese Werte werden über app.config.ts in die App eingebettet.

# Supabase Projekt-URL (z.B. https://xxxxxxxx.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=

# Supabase "anon" / public key (KEIN service_role key in der App!)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Tiefen-Link-Schema / Web-URL für Einladungslinks
EXPO_PUBLIC_APP_SCHEME=foreverly
EXPO_PUBLIC_INVITE_BASE_URL=https://foreverly.app/invite
