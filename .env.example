# Foreverly – Umgebungsvariablen
# Kopiere diese Datei nach `.env` und trage deine eigenen Werte ein.
# Diese Werte werden über app.config.ts in die App eingebettet.
# Ausführliche Anleitung: supabase/SUPABASE_SETUP.md

# --- Modus -----------------------------------------------------------------
# 'true'  = Demo-Modus mit Beispieldaten (keine echte Datenbank nötig)
# 'false' = echte Nutzer über Supabase (URL + Anon-Key erforderlich)
# Fehlt der Wert ODER fehlen die Supabase-Keys, läuft die App im Demo-Modus.
EXPO_PUBLIC_DEMO_MODE=true

# --- Supabase --------------------------------------------------------------
# Projekt-URL (z.B. https://xxxxxxxx.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=

# "anon" / public key (KEIN service_role key in der App!)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Links -----------------------------------------------------------------
# Tiefen-Link-Schema (App) und Basis-URL für Einladungslinks.
# Für die Web-Vorschau z.B. https://lamorstudios.github.io/FOREVERLY/invite
EXPO_PUBLIC_APP_SCHEME=foreverly
EXPO_PUBLIC_INVITE_BASE_URL=https://foreverly.app/invite
